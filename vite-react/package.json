{
  "name": "balneabilidade-praias-sc",
  "private": true,
  "version": "1.0",
  "main": "index.js",
  "author": {
    "name": "Rodrigo Pereira",
    "email": "rodrigopluz@gmail.com"
  },
  "license": "Apache License 2.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "yarn workspace @balneabilidade/client dev",
    "dev:backend": "yarn workspace @balneabilidade/server dev",
    "dev": "concurrently \"yarn run dev:frontend\" \"yarn run dev:backend\"",
    "test": "yarn workspace @balneabilidade/client test && yarn workspace @balneabilidade/server test",
    "test:coverage": "yarn workspace @balneabilidade/client test:coverage && yarn workspace @balneabilidade/server test:coverage",
    "test:ci": "yarn workspace @balneabilidade/client test:ci && yarn workspace @balneabilidade/server test:ci",
    "test:integration": "yarn workspace @balneabilidade/server test:integration",
    "perf:load": "yarn workspace @balneabilidade/server perf:load",
    "perf:benchmark": "yarn workspace @balneabilidade/server perf:benchmark",
    "perf:k6": "yarn workspace @balneabilidade/server perf:k6",
    "perf:k6:stress": "yarn workspace @balneabilidade/server perf:k6:stress",
    "prepare": "husky install"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "husky": "^9.1.7",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "@balneabilidade/client": "*",
    "@balneabilidade/server": "*"
  }
}